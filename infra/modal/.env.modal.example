# Modal local environment configuration
# Copy to .env.modal and adjust values as needed.

# Modal app name override
MODAL_APP_NAME=model2vec-embeddings

# Modal persistent volume for models
MODEL_VOLUME_NAME=embedding-models

# Mounted model path inside container
MODEL_PATH=/app/models

# Optional secrets (created in Modal)
AUTH_SECRET_NAME=model2vec-auth
# HF_SECRET_NAME=

# Hugging Face auth (if needed; prefer Modal secrets for production)
# HF_TOKEN=
# or HUGGINGFACE_HUB_TOKEN=

# Model defaults
MODEL_NAME=minishlab/potion-multilingual-128M
ALIAS_MODEL_NAME=potion-multilingual-128M
LAZY_LOAD_MODEL=false
